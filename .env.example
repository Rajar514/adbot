# Get API_ID & API_HASH from https://my.telegram.org
API_ID=1234567
API_HASH=abcdef0123456789abcdef0123456789

# Main control bot (get from @BotFather)
BOT_TOKEN=your_main_bot_token_here

# Logs bot — sends per-group delivery logs (get from @BotFather)
LOGS_BOT_TOKEN=your_logs_bot_token_here

# Comma-separated Telegram user IDs of admins (for /restart command)
ADMINS=123456789

# Persistent data dir
DATA_DIR=/data

# HTTP healthcheck port
PORT=8080

# Max Telegram accounts per user
MAX_ACCOUNTS=5

# Concurrent sends per account (lower = safer)
SEND_CONCURRENCY=6

# Delay range between sends (seconds)
SEND_DELAY_MIN=0.4
SEND_DELAY_MAX=1.2

# 1 = log every group send, 0 = only cycle summaries
LOG_VERBOSE=1

# Refresh group list every N cycles
GROUPS_REFRESH_EVERY=5

# Watchdog timeout in seconds
WATCHDOG_TIMEOUT=600
